{
  "arrow-function": {
    "prefix": "afn",
    "body": [
      "const $1 = ($2) => {",
      "  $3",
      "}",
      ""
    ]
  },
  "try-catch": {
    "prefix": "tc",
    "body": [
      "try {",
      "  const {} = await $1;",
      "} catch(e) {",
      "  console.error(e)",
      "}"
    ]
  },
  "console-log": {
    "prefix": "cl",
    "body": [
      "console.log($1)"
    ]
  },
  "console-error": {
    "prefix": "ce",
    "body": [
      "console.error($1)"
    ]
  },
  "console-table": {
    "prefix": "ct",
    "body": [
      "console.table({$1})"
    ]
  }
}
