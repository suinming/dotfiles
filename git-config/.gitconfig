[core]
  editor = nvim
  excludesfile = ~/.gitignore_global
[alias]
    br = branch
    co = checkout
    aa = add --all
    cm = commit
    ac = !git add --all && git commit
    gcw = "!sh $HOME/dotfiles/myscripts/scripts/gcw.sh"
[commit]
    template = ~/.gitmessage
